generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  password      String?        // naujas — bcrypt hash
  emailVerified DateTime?      // reikia Auth.js
  image         String?
  role          String         @default("USER")
  status        String         @default("PENDING")

  accounts      Account[]
  sessions      Session[]
  sheets        MonthlySheet[]
  categories    Category[]
  sharedWithMe  SharedAccess[] @relation("SharedToUser")
  myShares      SharedAccess[] @relation("SharedFromUser")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
}

model Category {
  id            String        @id @default(cuid())
  name          String
  type          String
  icon          String?
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions  Transaction[]

  @@unique([userId, type, name])
}

model MonthlySheet {
  id            String        @id @default(cuid())
  month         Int
  year          Int
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transactions  Transaction[]
  capitals      Capital[]

  createdAt     DateTime      @default(now())
  
  @@unique([month, year, userId]) // Neleidžia tam pačiam vartotojui turėti dublikatų tam pačiam mėnesiui
}

model Transaction {
  id             String       @id @default(cuid())
  amount         Float
  description    String?
  date           DateTime     @default(now())
  type           String       // INCOME arba EXPENSE
  
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  
  monthlySheetId String
  monthlySheet   MonthlySheet @relation(fields: [monthlySheetId], references: [id], onDelete: Cascade)
  
  isRecurring    Boolean      @default(false)
}

model Capital {
  id             String       @id @default(cuid())
  name           String       // Pvz. "Savings", "Cash", "Crypto"
  amount         Float
  percentage     Float?       // Galima skaičiuoti dinamiškai arba saugoti
  
  monthlySheetId String
  monthlySheet   MonthlySheet @relation(fields: [monthlySheetId], references: [id], onDelete: Cascade)
}

model SharedAccess {
  id             String   @id @default(cuid())
  
  // Kas dalinasi
  ownerId        String
  owner          User     @relation("SharedFromUser", fields: [ownerId], references: [id])
  
  // Kam dalinasi
  sharedWithId   String
  sharedWith     User     @relation("SharedToUser", fields: [sharedWithId], references: [id])
  
  createdAt      DateTime @default(now())

  @@unique([ownerId, sharedWithId])
}
