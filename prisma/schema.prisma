generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique // Ryšys su Clerk autentifikacija
  email         String         @unique
  name          String?
  role          String         @default("USER") // ADMIN arba USER
  status        String         @default("PENDING") // PENDING arba ACTIVE
  
  // Ryšiai
  sheets        MonthlySheet[]
  sharedWithMe  SharedAccess[] @relation("SharedToUser")
  myShares      SharedAccess[] @relation("SharedFromUser")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Category {
  id            String        @id @default(cuid())
  name          String
  type          String        // INCOME arba EXPENSE
  icon          String?
  
  transactions  Transaction[]
}

model MonthlySheet {
  id            String        @id @default(cuid())
  month         Int
  year          Int
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transactions  Transaction[]
  capitals      Capital[]

  createdAt     DateTime      @default(now())
  
  @@unique([month, year, userId]) // Neleidžia tam pačiam vartotojui turėti dublikatų tam pačiam mėnesiui
}

model Transaction {
  id             String       @id @default(cuid())
  amount         Float
  description    String?
  date           DateTime     @default(now())
  type           String       // INCOME arba EXPENSE
  
  categoryId     String
  category       Category     @relation(fields: [categoryId], references: [id])
  
  monthlySheetId String
  monthlySheet   MonthlySheet @relation(fields: [monthlySheetId], references: [id], onDelete: Cascade)
  
  isRecurring    Boolean      @default(false)
}

model Capital {
  id             String       @id @default(cuid())
  name           String       // Pvz. "Savings", "Cash", "Crypto"
  amount         Float
  percentage     Float?       // Galima skaičiuoti dinamiškai arba saugoti
  
  monthlySheetId String
  monthlySheet   MonthlySheet @relation(fields: [monthlySheetId], references: [id], onDelete: Cascade)
}

model SharedAccess {
  id             String   @id @default(cuid())
  
  // Kas dalinasi
  ownerId        String
  owner          User     @relation("SharedFromUser", fields: [ownerId], references: [id])
  
  // Kam dalinasi
  sharedWithId   String
  sharedWith     User     @relation("SharedToUser", fields: [sharedWithId], references: [id])
  
  createdAt      DateTime @default(now())

  @@unique([ownerId, sharedWithId])
}
